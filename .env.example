# APP ENVIRONMENT
APP_ENV=dev

# POSTGRES (PGVector)
DATABASE_URL=postgresql://dlm_user:dlm_pass@localhost:5432/dlm_db

# NEO4J (Graph)
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=dlm_dev_pass

# REDIS (Celery Broker/Cache)
REDIS_URL=redis://localhost:6379/0

# QDRANT (Standalone Vector)
QDRANT_URL=http://localhost:6333
QDRANT_GRPC_PORT=6334

# LLM SECRETS (Optional - provide your own)
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# SEARCH DEFAULTS
HYBRID_RETRIEVAL_STRATEGY=rrf
DEFAULT_LIMIT=10
RERANK_THRESHOLD=25
